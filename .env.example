# IMP CNC Production Tracking Prototype
# Single-machine scope only (HAAS_VF2_01)

# Backend runtime
DATABASE_PATH=data/imp_cnc_demo.db
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Frontend runtime hints
FRONTEND_PORT=5173

# AI analysis-only configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Simulator timing hint for manual demo runs
# (kept for config parity; current simulator flow is operator-triggered)
PART_COMPLETION_INTERVAL_SECONDS=5
